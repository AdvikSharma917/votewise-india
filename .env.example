GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
PORT=3000

# Optional: enables real anonymous quiz-result writes to Firestore from the backend.
# On Cloud Run, prefer GOOGLE_CLOUD_PROJECT plus a service account with Firestore permissions.
FIRESTORE_PROJECT_ID=
FIRESTORE_COLLECTION=quizResults
